   {set $voxnotes rb2}
   {set $voxodcustomtexture TRUE}
   {set $voxod rb2}
   {set $crowdmetercustomtexture TRUE}
   {set $crowdmetertex rb2}
   {set $scorecustomtexture TRUE}
   {set $scoretex rb2}
